{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run predeploy:env && VITE_API_URL=/api npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://luminous-reflection-production-b35f.up.railway.app/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://luminous-reflection-production-b35f.up.railway.app/socket.io/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

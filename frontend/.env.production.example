# ───────── Far Away frontend — PRODUCTION env ─────────
# Base URL of your deployed backend API, INCLUDING the /api suffix.
# When serving the frontend behind the same nginx that proxies the API
# (see docker-compose.prod.yml), use a relative path instead: VITE_API_URL=/api
VITE_API_URL=https://your-backend-domain.com/api

# Google OAuth Web Client ID. Match backend GOOGLE_CLIENT_ID.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

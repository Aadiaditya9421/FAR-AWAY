# SkillPath backend env for one VPS with docker-compose.prod.yml bundled MongoDB/Redis.
# Copy to backend/.env, then replace all placeholders before running the stack.

PORT=5000
NODE_ENV=production

CLIENT_URL=https://yourdomain.com
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
TRUST_PROXY=1

MONGO_URI=mongodb://mongo:27017/skillpath
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379

JWT_ACCESS_SECRET=replace-with-openssl-rand-base64-48
JWT_REFRESH_SECRET=replace-with-a-different-openssl-rand-base64-48
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your-smtp-api-key
SMTP_FROM="SkillPath <no-reply@yourdomain.com>"

SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=change-this-to-a-strong-password

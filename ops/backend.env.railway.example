# Far Away backend - Railway service variables
# Paste this into Railway service -> Variables -> RAW Editor and replace values.

NODE_ENV=production
TRUST_PROXY=1

# Fill this after Vercel gives you the frontend URL.
CLIENT_URL=https://your-vercel-project.vercel.app
CORS_ORIGINS=https://your-vercel-project.vercel.app

# Use MongoDB Atlas for Railway split deployment.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/far-away?retryWrites=true&w=majority

# Add a Railway Redis service to the same project, then reference its URL.
# If your Redis service has a different name, use Railway autocomplete for REDIS_URL.
REDIS_ENABLED=true
REDIS_URL=${{Redis.REDIS_URL}}

# Generate two different secrets with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace-with-openssl-rand-base64-48
JWT_REFRESH_SECRET=replace-with-a-different-openssl-rand-base64-48
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Use the same Web Client ID in Vercel as VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Optional AI tutor provider.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Required for forgot-password emails.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your-smtp-api-key
SMTP_FROM="Far Away <no-reply@yourdomain.com>"

# SkillPath root Compose env.
# Copy this file to .env in the project root when using docker-compose.prod.yml.
# The root .env is read by Docker Compose for build args and service overrides.
# It is not the same file as backend/.env.

# Keep /api for same-origin nginx proxy mode.
VITE_API_URL=/api

# Public Google OAuth Web Client ID. Use the same value as backend GOOGLE_CLIENT_ID.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Default exposes the frontend on host port 80.
# Use 127.0.0.1:8080 when a host-level HTTPS proxy terminates TLS.
FRONTEND_PORT=80

# Optional managed-service overrides. Leave commented for bundled MongoDB/Redis.
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/skillpath?retryWrites=true&w=majority
# REDIS_ENABLED=true
# REDIS_URL=rediss://default:PASSWORD@your-redis-host:6379

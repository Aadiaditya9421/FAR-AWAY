# ───────────── Far Away backend — PRODUCTION env ─────────────
# Copy this file to `.env` on your host (or paste the values into your hosting
# provider's dashboard). NEVER commit the real .env — it is git-ignored.

PORT=5000
NODE_ENV=production

# Public URL(s) of your deployed frontend, used for CORS.
# Use CORS_ORIGINS (comma-separated) if you have more than one domain.
CLIENT_URL=https://your-frontend-domain.com
CORS_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# Behind a reverse proxy / platform load balancer (Render, Railway, Fly, nginx).
TRUST_PROXY=1

# ── MongoDB Atlas ──
# Atlas > Database > Connect > Drivers. Include the DB name (far-away) before the ?.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/far-away?retryWrites=true&w=majority

# ── Redis (Upstash / Redis Cloud) ──
# Use rediss:// (TLS) for managed providers. Set REDIS_ENABLED=false to skip Redis.
REDIS_ENABLED=true
REDIS_URL=rediss://default:PASSWORD@your-redis-host:6379

# ── JWT secrets ──
# Generate each with:  openssl rand -base64 48   (must be unique, >=32 chars)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Google OAuth Web Client ID. Use the same value in frontend VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── SMTP (Resend / SendGrid / Mailgun / Gmail App Password) ──
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your-smtp-api-key
SMTP_FROM="Far Away <no-reply@yourdomain.com>"

# ── Seed admin (used only when you run `npm run seed`) ──
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=change-this-to-a-strong-password

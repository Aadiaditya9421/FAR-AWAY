# Far Away backend - production env
# Copy this file to backend/.env on your host, or paste these variables into
# your hosting provider's dashboard. Never commit real .env files.
#
# Single-VPS Docker Compose with bundled MongoDB/Redis can use:
#   MONGO_URI=mongodb://mongo:27017/far-away
#   REDIS_URL=redis://redis:6379
#
# Managed hosting should use Atlas/Redis Cloud/Upstash-style URLs instead.

PORT=5000
NODE_ENV=production

# Public URL(s) of your deployed frontend, used for reset links and CORS.
CLIENT_URL=https://yourdomain.com
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Required behind reverse proxies and platform load balancers.
TRUST_PROXY=1

# MongoDB.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/far-away?retryWrites=true&w=majority

# Redis. Use rediss:// for managed TLS Redis providers.
REDIS_ENABLED=true
REDIS_URL=rediss://default:PASSWORD@your-redis-host:6379

# JWT secrets. Generate each with: openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Google OAuth Web Client ID. Use the same value in VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Optional AI tutor provider. Leave blank to use deterministic fallbacks.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# SMTP for forgot-password emails.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your-smtp-api-key
SMTP_FROM="Far Away <no-reply@yourdomain.com>"

# Used only when you intentionally run npm run seed.
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=change-this-to-a-strong-password

PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

MONGO_URI=mongodb://localhost:27017/far-away
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace-with-a-long-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ---------------------------------------------------------------------------
# SMTP / Email
# ---------------------------------------------------------------------------
# Leave SMTP_HOST empty to run without email: messages are logged to the
# console (development) instead of being delivered.
#
# Common providers (set SMTP_USER / SMTP_PASS to your credentials):
#   Gmail (App Password):  SMTP_HOST=smtp.gmail.com      SMTP_PORT=587
#   SendGrid:              SMTP_HOST=smtp.sendgrid.net    SMTP_PORT=587   SMTP_USER=apikey
#   Mailgun:               SMTP_HOST=smtp.mailgun.org     SMTP_PORT=587
#   Mailtrap (testing):    SMTP_HOST=sandbox.smtp.mailtrap.io  SMTP_PORT=2525
#
# SMTP_SECURE: set true for implicit TLS (port 465). For 587/2525 (STARTTLS)
# leave it false. If unset, it defaults to true only when SMTP_PORT=465.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Far Away <no-reply@far-away.local>"
SMTP_REPLY_TO=
# Reuse pooled connections instead of one per email (recommended).
SMTP_POOL=true
# Only set to false for local relays using self-signed certificates.
SMTP_TLS_REJECT_UNAUTHORIZED=true

SEED_ADMIN_EMAIL=admin@faraway.local
SEED_ADMIN_PASSWORD=Admin1234

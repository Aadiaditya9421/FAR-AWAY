PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

MONGO_URI=mongodb://localhost:27017/skillpath
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace-with-a-long-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

GOOGLE_CLIENT_ID=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Code execution runs on the backend, never in the browser.
# Prefer Judge0 or Piston for isolated multi-language execution.
JUDGE0_URL=
JUDGE0_API_KEY=
PISTON_ENABLED=false
PISTON_URL=

# Trusted local development only. Keep false for production unless the backend
# runs inside a dedicated sandbox/worker container.
LOCAL_COMPILER_ENABLED=false

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SkillPath <no-reply@skillpath.local>"

SEED_ADMIN_EMAIL=admin@skillpath.local
SEED_ADMIN_PASSWORD=Admin1234
